---
layout: base.njk
---
<article class="blog-post">
  <header class="post-header">
    <h1>{{ title }}</h1>
    <div class="post-meta">
      <span class="post-author">{{ author or site.owner }}</span>
      <time>{{ date | readableDate }}</time>
    </div>
    {% if categories %}
    <div class="post-categories">
      {% for cat in categories %}<span class="category-tag">{{ cat }}</span>{% endfor %}
    </div>
    {% endif %}
  </header>

  <div class="post-content">
    {{ content | safe }}
  </div>

  {% if tags %}
  <footer class="post-footer">
    <div class="post-tags">
      {% for tag in tags %}{% if tag != "post" %}<span class="post-tag">{{ tag }}</span>{% endif %}{% endfor %}
    </div>
  </footer>
  {% endif %}

  <div class="post-cta">
    <p>Ready to get your piano tuned? <a href="/appointments/">Book an appointment</a> or call Jake at <a href="tel:{{ site.phonePlain }}">{{ site.phone }}</a>.</p>
  </div>
</article>
